# Weights-base image: pinned upstream vLLM + baked-in test model weights.
# NIXL is intentionally NOT installed here; the per-PR build (Dockerfile.vllm)
# layers the freshly-built PR wheels on top of this image. Baking the weights in keeps
# the per-PR path free of any HuggingFace / Docker Hub dependency.
# BASE_IMAGE is pinned to a concrete version so the per-PR sanity gate is reproducible;
# bump it (and CI_IMAGE_TAG) deliberately to move to a newer vLLM.
ARG BASE_IMAGE=docker.io/vllm/vllm-openai:v0.23.0
FROM --platform=$TARGETPLATFORM ${BASE_IMAGE}

ARG MODEL_ID=Qwen/Qwen3-1.7B
ARG MODEL_DIR=/models

ENV NIXL_SANITY_MODEL_ID=${MODEL_ID}
ENV NIXL_SANITY_MODEL_DIR=${MODEL_DIR}
ENV HF_HOME=${MODEL_DIR}/hf-home

# iproute2 provides `ss`, used by the sanity's get_next_tcp_port helper to skip occupied
# host ports (concurrent jobs share a SLURM node under host networking).
RUN apt-get update \
 && apt-get install -y --no-install-recommends iproute2 \
 && rm -rf /var/lib/apt/lists/*

# huggingface_hub ships in the vLLM image; download once at build time so PR runs
# never touch HuggingFace. A token is only needed for gated models (default is ungated).
# Use the `hf` CLI (huggingface-cli is removed in recent huggingface_hub). Pin the version
# so rebuilds don't drift to a newer PyPI release.
RUN python3 -m pip install --no-cache-dir "huggingface_hub[cli]==1.21.0" \
 && hf download "${MODEL_ID}" \
      --local-dir "${MODEL_DIR}/${MODEL_ID}" \
 && ls -la "${MODEL_DIR}/${MODEL_ID}"
