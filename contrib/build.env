set +e
set -x

# Check if script is being sourced
if [ "${BASH_SOURCE[0]}" = "$0" ]; then
    # Script is being executed directly
    echo "ERROR: This script is not meant to be executed directly"
    exit 1
fi

# Build Environment Variables
NIXL_SCRIPTS_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
export NIXL_SCRIPTS_DIR

# Build and test configuration
export UCX_VERSION=1.18.0
export UCX_INSTALL_DIR=/opt/nvidia/ucx
export NIXL_BUILD_DIR=nixl_build
export NIXL_INSTALL_DIR=/opt/nvidia/nxil

# Source build functions
if [ ! -f "$NIXL_SCRIPTS_DIR/build-functions.sh" ]; then
    echo "ERROR: build-functions.sh not found"
    return 1
fi

# shellcheck disable=SC1091
. "$NIXL_SCRIPTS_DIR/build-functions.sh" || {
    echo "ERROR: Failed to source build-functions.sh"
    return 1
}
